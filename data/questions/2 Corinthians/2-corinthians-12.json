{"book":"2 Corinthians","chapter":12,"questions":[{"id":"2cor-12-q1","type":"multiple_choice","question":"Paul describes a man caught up to which heaven?","options":["The first heaven","The second heaven","The third heaven","The seventh heaven"],"answer":"The third heaven","verse_reference":"2 Corinthians 12:2"},{"id":"2cor-12-q2","type":"multiple_choice","question":"What was given to Paul to keep him from becoming conceited?","options":["A physical disability","A thorn in the flesh","Poverty","Imprisonment"],"answer":"A thorn in the flesh","verse_reference":"2 Corinthians 12:7"},{"id":"2cor-12-q3","type":"true_false","question":"God removed the thorn from Paul after he prayed three times.","answer":"false","verse_reference":"2 Corinthians 12:8-9"},{"id":"2cor-12-q4","type":"fill_blank","question":"My grace is sufficient for you, for my power is made perfect in _____.","answer":"weakness","verse_reference":"2 Corinthians 12:9"},{"id":"2cor-12-q5","type":"fill_blank","question":"When I am weak, then I am _____.","answer":"strong","verse_reference":"2 Corinthians 12:10"}]}
